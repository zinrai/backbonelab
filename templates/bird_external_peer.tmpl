router id {{.RouterID}};

log stderr all;

protocol device {
}

protocol direct {
    ipv4;
}

protocol kernel {
    ipv4 {
        export all;
        import none;
    };
}

# Advertise own prefix only (peering behavior)
protocol static {
    ipv4;
    route {{.Loopback}} blackhole;
}

{{- range .EBGPSessions}}
protocol bgp ebgp_{{.SanitizedName}} {
    local as {{$.ASN}};
    neighbor {{.PeerAddr}} as {{.PeerASN}};
    ipv4 {
        import all;
        export all;
    };
}
{{end}}
